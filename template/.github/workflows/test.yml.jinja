name: Test

on:
  push:
    paths-ignore:
      - 'docs/**'
      - 'CHANGELOG.md'
      - 'README.md'
  pull_request:
    paths-ignore:
      - 'docs/**'
      - 'CHANGELOG.md'
      - 'README.md'

jobs:
  test:
    name: Test

    runs-on: ubuntu-24.04

    strategy:
      fail-fast: false
      matrix:
        python-version: [
            {%- set versions = [8, 9, 10, 11, 12, 13, 14] | select("ge", (minimum_python_version.split(".")[1] | int)) | list %}
            {%- for v in versions -%}
                {%- if v != versions | last -%}
                    {{ "3.%d, " | format(v) }}
                {%- else -%}
                    {{ "3.%d" | format(v) }}
                {%- endif -%}
            {%- endfor -%}
        ]

    steps:
      - uses: actions/checkout@v6

      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: ${{ '{{ matrix.python-version }}' }}

      - name: Install uv
        uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true

      - name: Install dependencies
        run: |
          uv sync --python ${{ '{{ matrix.python-version }}' }} --no-dev --frozen

      - name: Test with pytest
        run: |
          uv sync --frozen --group test
          uv run pytest

      # - name: Upload coverage to Codecov
      #   uses: codecov/codecov-action@v5
      #   with:
      #     token: ${{ '{{ secrets.CODECOV_TOKEN }}' }}
      #     files: ./coverage.xml
